# ============================================================
# Friendly Text Moderator — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below.
# 3. NEVER commit .env — it is already in .gitignore.
#
# On Vercel: set these in Project Settings → Environment Variables.
# All variable names MUST start with VITE_ or Vite will exclude
# them from the browser bundle for security reasons.
# ============================================================

# --- Hugging Face API (REQUIRED) ---
# Get a free token at: https://huggingface.co/settings/tokens
# Required permission: "Make calls to the serverless Inference API"
VITE_HF_API_KEY=hf_your_api_key_here

# Hugging Face Inference API base URL
# Do not change unless you are self-hosting the inference API.
VITE_HF_API_URL=https://api-inference.huggingface.co

# Hugging Face model to use for toxicity classification.
# Recommended: unitary/toxic-bert  (6-label multi-class, English)
# Alternatives:
#   unitary/multilingual-toxic-xlm-roberta  (multi-language)
#   KoalaAI/Text-Moderation                (OpenAI moderation-style labels)
VITE_HF_MODEL_ID=unitary/toxic-bert

# --- Application Settings (OPTIONAL) ---

# Display name shown in the navbar and hero
VITE_APP_NAME=Friendly Text Moderator

# Hard limit on text length sent to the API (characters)
VITE_MAX_CHAR_LIMIT=5000

# Request timeout in milliseconds
# The X-Wait-For-Model header keeps the connection open during cold starts,
# so this should be at least 30 000 ms (30 s).
VITE_REQUEST_TIMEOUT=30000

# Minimum score (0–1) for a toxicity label to be marked as "detected"
VITE_TOXICITY_THRESHOLD=0.5
